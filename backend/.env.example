# ── AI / HuggingFace ──────────────────────────────────────────────────────────
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# Optional: override the default model IDs
# MATCHER_REPO_ID=Qwen/Qwen2.5-7B-Instruct
# CHATBOT_REPO_ID=meta-llama/Llama-3.1-8B-Instruct
# EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── LangSmith (optional tracing) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=ResumeAI-ATS

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ats_db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_ALGORITHM=HS256

# ── Email (Gmail SMTP fallback) ───────────────────────────────────────────────
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Encryption (for stored SMTP passwords) ───────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SMTP_ENCRYPTION_KEY=your_fernet_key_here

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
CORS_ORIGINS=http://localhost:5173

# ── File Directories ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
TEMP_DIR=temp
